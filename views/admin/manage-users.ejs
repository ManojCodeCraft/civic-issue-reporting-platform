<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - CivicTrack
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <%- include('../partials/navbar') %>

        <div class="container">
            <div class="page-header">
                <h1>👥 Manage Users</h1>
                <p>View and manage all system users</p>
            </div>

            <% if (error && error.length> 0) { %>
                <div class="alert alert-error">
                    <%= error %>
                </div>
                <% } %>

                    <% if (success && success.length> 0) { %>
                        <div class="alert alert-success">
                            <%= success %>
                        </div>
                        <% } %>

                            <!-- User Stats -->
                            <div class="stats-grid stats-grid-4">
                                <div class="stat-card">
                                    <div class="stat-icon">👥</div>
                                    <div class="stat-content">
                                        <h3>
                                            <%= userStats.total %>
                                        </h3>
                                        <p>Total Users</p>
                                    </div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-icon">👤</div>
                                    <div class="stat-content">
                                        <h3>
                                            <%= userStats.citizens %>
                                        </h3>
                                        <p>Citizens</p>
                                    </div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-icon">🏢</div>
                                    <div class="stat-content">
                                        <h3>
                                            <%= userStats.authorities %>
                                        </h3>
                                        <p>Authorities</p>
                                    </div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-icon">⚙️</div>
                                    <div class="stat-content">
                                        <h3>
                                            <%= userStats.admins %>
                                        </h3>
                                        <p>Admins</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Filters -->
                            <div class="filters-section">
                                <form method="GET" action="/admin/manage-users" class="filters-form">
                                    <div class="filter-group">
                                        <label for="role">Role</label>
                                        <select id="role" name="role" onchange="this.form.submit()">
                                            <option value="">All Roles</option>
                                            <% Object.values(roles).forEach(role=> { %>
                                                <option value="<%= role %>" <%=currentFilter.role===role ? 'selected'
                                                    : '' %>>
                                                    <%= role.charAt(0).toUpperCase() + role.slice(1) %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </div>

                                    <div class="filter-group">
                                        <input type="text" name="search" placeholder="Search by name or email..."
                                            value="<%= currentFilter.search || '' %>">
                                    </div>

                                    <button type="submit" class="btn btn-primary">🔍 Search</button>
                                    <button type="button" class="btn btn-secondary"
                                        onclick="window.location.href='/admin/manage-users'">
                                        Clear
                                    </button>
                                </form>
                            </div>

                            <!-- Users Table -->
                            <div class="table-responsive">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Phone</th>
                                            <th>Role</th>
                                            <th>Department/Address</th>
                                            <th>Status</th>
                                            <th>Joined</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% users.forEach(user=> { %>
                                            <tr>
                                                <td><strong>
                                                        <%= user.name %>
                                                    </strong></td>
                                                <td>
                                                    <%= user.email %>
                                                </td>
                                                <td>
                                                    <%= user.phone %>
                                                </td>
                                                <td>
                                                    <span class="badge badge-<%= user.role %>">
                                                        <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <small>
                                                        <%= user.department || user.address || 'N/A' %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (user.isActive) { %>
                                                        <span class="badge badge-success">Active</span>
                                                        <% } else { %>
                                                            <span class="badge badge-danger">Inactive</span>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <%= new Date(user.createdAt).toLocaleDateString() %>
                                                </td>
                                                <td>
                                                    <form action="/admin/toggle-user/<%= user._id %>" method="POST"
                                                        style="display: inline;">
                                                        <button type="submit"
                                                            class="btn btn-xs <%= user.isActive ? 'btn-danger' : 'btn-success' %>">
                                                            <%= user.isActive ? 'Deactivate' : 'Activate' %>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
        </div>

        <%- include('../partials/footer') %>
</body>

</html>