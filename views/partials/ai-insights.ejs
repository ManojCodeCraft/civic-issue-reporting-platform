<div class="ai-insights-widget">
    <h3>🤖 AI Insights</h3>

    <% if (issue.aiAnalysis && issue.aiAnalysis.suggestedCategory) { %>
        <div class="insight-item">
            <div class="insight-label">AI Classification</div>
            <div class="insight-value">
                <%= issue.aiAnalysis.suggestedCategory %>
                    <span class="confidence-badge">
                        <%= issue.aiAnalysis.categoryConfidence %>% confidence
                    </span>
            </div>
        </div>

        <div class="insight-item">
            <div class="insight-label">Priority Analysis</div>
            <div class="insight-value">
                <span class="priority-badge priority-<%= issue.priority.toLowerCase() %>">
                    <%= issue.priority %>
                </span>
                <small>Score: <%= issue.aiAnalysis.priorityScore %>/7</small>
            </div>
        </div>

        <div class="insight-item">
            <div class="insight-label">Sentiment</div>
            <div class="insight-value" style="text-transform: capitalize;">
                <%= issue.aiAnalysis.sentiment %>
                    <small>(Score: <%= issue.aiAnalysis.sentimentScore %>)</small>
            </div>
        </div>

        <div class="insight-item">
            <div class="insight-label">Urgency Level</div>
            <div class="insight-value">
                <%= issue.aiAnalysis.urgency %>
            </div>
        </div>

        <% if (issue.aiAnalysis.keywords && issue.aiAnalysis.keywords.length> 0) { %>
            <div class="insight-item">
                <div class="insight-label">Key Topics</div>
                <div class="keywords-display">
                    <% issue.aiAnalysis.keywords.slice(0, 5).forEach(keyword=> { %>
                        <span class="keyword-chip">
                            <%= keyword %>
                        </span>
                        <% }) %>
                </div>
            </div>
            <% } %>

                <small style="color: #6b7280; font-size: 11px; margin-top: 12px; display: block;">
                    Analyzed: <%= new Date(issue.aiAnalysis.analyzedAt).toLocaleString() %>
                </small>
                <% } else { %>
                    <p style="color: #6b7280; font-size: 14px;">No AI analysis available for this issue.</p>
                    <% } %>
</div>

<style>
    .ai-insights-widget {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 20px;
        border-radius: 12px;
        color: white;
        margin-bottom: 24px;
    }

    .ai-insights-widget h3 {
        margin: 0 0 16px 0;
        font-size: 18px;
    }

    .insight-item {
        background: rgba(255, 255, 255, 0.15);
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 12px;
    }

    .insight-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.8;
        margin-bottom: 4px;
    }

    .insight-value {
        font-size: 16px;
        font-weight: 600;
    }

    .confidence-badge {
        font-size: 12px;
        background: rgba(255, 255, 255, 0.2);
        padding: 2px 8px;
        border-radius: 10px;
        margin-left: 8px;
    }

    .keywords-display {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 6px;
    }

    .keyword-chip {
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 12px;
    }
</style>